// ============================================================
// Checkpoint v1.5 — Schema Prisma
// Banco: SQLite (dev/acadêmico) → trocar provider para
//        postgresql para produção real
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Usuário ───────────────────────────────────────────────
model TAB_USUARIO {
  id_usuario    Int      @id @default(autoincrement())
  nm_usuario    String   @unique
  email_usuario String   @unique
  senha_usuario String
  bio_usuario   String?
  img_usuario   String?
  tipo_usuario  String   @default("USER")   // "USER" | "ADMIN"
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relações
  avaliacoes   TAB_AVALIACAO[]
  listas       TAB_LISTA[]
  status_jogos TAB_STATUS_JOGO[]
  seguidores   TAB_FOLLOW[]     @relation("seguidos")
  seguindo     TAB_FOLLOW[]     @relation("seguidores")
  likes_dados  TAB_LIKE_REVIEW[]

  @@map("TAB_USUARIO")
}

// ── Jogo ──────────────────────────────────────────────────
model TAB_JOGOS {
  id_jogo       Int      @id @default(autoincrement())
  id_usuario    Int                              // admin criador
  nm_jogo       String   @unique
  img_jogo      String
  genero        String?
  plataforma    String?
  classificacao String?
  descricao     String?
  dt_jogo       DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relações
  avaliacoes   TAB_AVALIACAO[]
  listas       TAB_LISTA_JOGO[]
  status_jogos TAB_STATUS_JOGO[]

  @@map("TAB_JOGOS")
}

// ── Avaliação ─────────────────────────────────────────────
// nota: escala 1-10 (0.5 a 5 estrelas em incrementos de 0.5)
//       1=0.5★, 2=1★, 3=1.5★, 4=2★, 5=2.5★, 6=3★, 7=3.5★, 8=4★, 9=4.5★, 10=5★
// comentario: opcional (pode avaliar só com nota, como no Letterboxd)
model TAB_AVALIACAO {
  id_avaliacao Int      @id @default(autoincrement())
  id_usuario   Int
  id_jogo      Int
  nota         Int                              // 1-10 (meia estrela)
  comentario   String?                          // v1.5: opcional
  data_jogada  DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relações
  usuario TAB_USUARIO @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogo    TAB_JOGOS   @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)
  likes   TAB_LIKE_REVIEW[]

  @@unique([id_usuario, id_jogo])
  @@map("TAB_AVALIACAO")
}

// ── Like em Avaliação (v1.5) ──────────────────────────────
model TAB_LIKE_REVIEW {
  id_like      Int      @id @default(autoincrement())
  id_usuario   Int
  id_avaliacao Int
  created_at   DateTime @default(now())

  usuario  TAB_USUARIO   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  avaliacao TAB_AVALIACAO @relation(fields: [id_avaliacao], references: [id_avaliacao], onDelete: Cascade)

  @@unique([id_usuario, id_avaliacao])
  @@map("TAB_LIKE_REVIEW")
}

// ── Lista de Jogos ────────────────────────────────────────
model TAB_LISTA {
  id_lista   Int      @id @default(autoincrement())
  id_usuario Int
  nm_lista   String
  descricao  String?
  publica    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usuario TAB_USUARIO    @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogos   TAB_LISTA_JOGO[]

  @@map("TAB_LISTA")
}

// ── Relação Lista ↔ Jogo ──────────────────────────────────
model TAB_LISTA_JOGO {
  id_lista Int
  id_jogo  Int

  lista TAB_LISTA @relation(fields: [id_lista], references: [id_lista], onDelete: Cascade)
  jogo  TAB_JOGOS @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)

  @@id([id_lista, id_jogo])
  @@map("TAB_LISTA_JOGO")
}

// ── Seguimento entre usuários ─────────────────────────────
model TAB_FOLLOW {
  id_usuario_seguidor Int
  id_usuario_seguido  Int
  created_at          DateTime @default(now())

  seguidor TAB_USUARIO @relation("seguidores", fields: [id_usuario_seguidor], references: [id_usuario], onDelete: Cascade)
  seguido  TAB_USUARIO @relation("seguidos",   fields: [id_usuario_seguido],  references: [id_usuario], onDelete: Cascade)

  @@id([id_usuario_seguidor, id_usuario_seguido])
  @@map("TAB_FOLLOW")
}

// ── Status de jogo na biblioteca ──────────────────────────
// top_position: 1-4 → posição na Vitrine; null → não está na Vitrine
model TAB_STATUS_JOGO {
  id_status    Int      @id @default(autoincrement())
  id_usuario   Int
  id_jogo      Int
  status       String   @default("QUERO_JOGAR") // QUERO_JOGAR|JOGANDO|ZERADO|ABANDONADO
  favorito     Boolean  @default(false)
  top_position Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  usuario TAB_USUARIO @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogo    TAB_JOGOS   @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)

  @@unique([id_usuario, id_jogo])
  @@map("TAB_STATUS_JOGO")
}
