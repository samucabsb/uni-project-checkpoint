// ============================================================
// Checkpoint v1.7 — Schema Prisma (SQLite)
// Mudanças v1.7:
//   - Campo jogadores em TAB_JOGOS
//   - TAB_REACAO_REVIEW substitui TAB_LIKE_REVIEW
//     (suporta LIKE e DISLIKE numa única tabela)
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// tipo_usuario: "USER" | "ADMIN"
model TAB_USUARIO {
  id_usuario    Int      @id @default(autoincrement())
  nm_usuario    String   @unique
  email_usuario String   @unique
  senha_usuario String
  bio_usuario   String?
  img_usuario   String?
  tipo_usuario  String   @default("USER")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  avaliacoes      TAB_AVALIACAO[]
  listas          TAB_LISTA[]
  status_jogos    TAB_STATUS_JOGO[]
  seguidores      TAB_FOLLOW[]           @relation("seguidos")
  seguindo        TAB_FOLLOW[]           @relation("seguidores")
  reacoes         TAB_REACAO_REVIEW[]
  comentarios     TAB_COMENTARIO_REVIEW[]
  atividades      TAB_ATIVIDADE[]        @relation("atividades_autor")
  atividades_alvo TAB_ATIVIDADE[]        @relation("atividades_alvo")
  diario          TAB_DIARIO_JOGO[]
  likes_listas    TAB_LIKE_LISTA[]

  @@index([nm_usuario])
  @@map("TAB_USUARIO")
}

// jogadores: "Solo" | "Até 2 jogadores" | "Multiplayer online" | etc.
model TAB_JOGOS {
  id_jogo       Int      @id @default(autoincrement())
  id_usuario    Int
  nm_jogo       String   @unique
  img_jogo      String
  genero        String?
  plataforma    String?
  classificacao String?
  jogadores     String?  // NOVO v1.7
  descricao     String?
  dt_jogo       DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  avaliacoes   TAB_AVALIACAO[]
  listas       TAB_LISTA_JOGO[]
  status_jogos TAB_STATUS_JOGO[]
  atividades   TAB_ATIVIDADE[]
  diario       TAB_DIARIO_JOGO[]

  @@index([nm_jogo])
  @@index([created_at])
  @@map("TAB_JOGOS")
}

// nota 1-10 → display = nota / 2 (0.5 a 5.0 estrelas)
model TAB_AVALIACAO {
  id_avaliacao Int       @id @default(autoincrement())
  id_usuario   Int
  id_jogo      Int
  nota         Int
  comentario   String?
  data_jogada  DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  usuario     TAB_USUARIO            @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogo        TAB_JOGOS              @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)
  reacoes     TAB_REACAO_REVIEW[]
  comentarios TAB_COMENTARIO_REVIEW[]
  atividades  TAB_ATIVIDADE[]

  @@unique([id_usuario, id_jogo])
  @@index([id_jogo, created_at])
  @@index([created_at])
  @@map("TAB_AVALIACAO")
}

// NOVO v1.7 — substitui TAB_LIKE_REVIEW
// tipo: "LIKE" | "DISLIKE"
// Regras: uma reação por usuário/avaliação; trocar remove a anterior
model TAB_REACAO_REVIEW {
  id_usuario   Int
  id_avaliacao Int
  tipo         String   // "LIKE" | "DISLIKE"
  created_at   DateTime @default(now())

  usuario   TAB_USUARIO   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  avaliacao TAB_AVALIACAO @relation(fields: [id_avaliacao], references: [id_avaliacao], onDelete: Cascade)

  @@id([id_usuario, id_avaliacao])
  @@index([id_avaliacao])
  @@map("TAB_REACAO_REVIEW")
}

model TAB_COMENTARIO_REVIEW {
  id_comentario Int      @id @default(autoincrement())
  id_usuario    Int
  id_avaliacao  Int
  texto         String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  usuario   TAB_USUARIO   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  avaliacao TAB_AVALIACAO @relation(fields: [id_avaliacao], references: [id_avaliacao], onDelete: Cascade)

  @@index([id_avaliacao])
  @@map("TAB_COMENTARIO_REVIEW")
}

model TAB_LISTA {
  id_lista   Int      @id @default(autoincrement())
  id_usuario Int
  nm_lista   String
  descricao  String?
  publica    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usuario    TAB_USUARIO      @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogos      TAB_LISTA_JOGO[]
  likes      TAB_LIKE_LISTA[]
  atividades TAB_ATIVIDADE[]

  @@index([id_usuario])
  @@index([created_at])
  @@map("TAB_LISTA")
}

model TAB_LISTA_JOGO {
  id_lista Int
  id_jogo  Int
  position Int?

  lista TAB_LISTA @relation(fields: [id_lista], references: [id_lista], onDelete: Cascade)
  jogo  TAB_JOGOS @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)

  @@id([id_lista, id_jogo])
  @@map("TAB_LISTA_JOGO")
}

model TAB_LIKE_LISTA {
  id_usuario Int
  id_lista   Int
  created_at DateTime @default(now())

  usuario TAB_USUARIO @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  lista   TAB_LISTA   @relation(fields: [id_lista], references: [id_lista], onDelete: Cascade)

  @@id([id_usuario, id_lista])
  @@map("TAB_LIKE_LISTA")
}

model TAB_FOLLOW {
  id_usuario_seguidor Int
  id_usuario_seguido  Int
  created_at          DateTime @default(now())

  seguidor TAB_USUARIO @relation("seguidores", fields: [id_usuario_seguidor], references: [id_usuario], onDelete: Cascade)
  seguido  TAB_USUARIO @relation("seguidos",   fields: [id_usuario_seguido],  references: [id_usuario], onDelete: Cascade)

  @@id([id_usuario_seguidor, id_usuario_seguido])
  @@index([id_usuario_seguido])
  @@map("TAB_FOLLOW")
}

// status: "QUERO_JOGAR" | "JOGANDO" | "ZERADO" | "ABANDONADO"
model TAB_STATUS_JOGO {
  id_status    Int      @id @default(autoincrement())
  id_usuario   Int
  id_jogo      Int
  status       String   @default("QUERO_JOGAR")
  favorito     Boolean  @default(false)
  top_position Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  usuario TAB_USUARIO @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogo    TAB_JOGOS   @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)

  @@unique([id_usuario, id_jogo])
  @@index([id_usuario])
  @@map("TAB_STATUS_JOGO")
}

// tipo: "AVALIOU_JOGO"|"CURTIU_REVIEW"|"CRIOU_LISTA"|"ADICIONOU_JOGO_LISTA"
//       |"FAVORITOU_JOGO"|"MUDOU_STATUS"|"SEGUIU_USUARIO"|"CURTIU_LISTA"
model TAB_ATIVIDADE {
  id_atividade    Int      @id @default(autoincrement())
  id_usuario      Int
  tipo            String
  id_jogo         Int?
  id_avaliacao    Int?
  id_lista        Int?
  id_usuario_alvo Int?
  dados_extras    String?
  created_at      DateTime @default(now())

  usuario      TAB_USUARIO    @relation("atividades_autor", fields: [id_usuario],      references: [id_usuario], onDelete: Cascade)
  usuario_alvo TAB_USUARIO?   @relation("atividades_alvo",  fields: [id_usuario_alvo], references: [id_usuario], onDelete: SetNull)
  jogo         TAB_JOGOS?     @relation(fields: [id_jogo],      references: [id_jogo],      onDelete: SetNull)
  avaliacao    TAB_AVALIACAO? @relation(fields: [id_avaliacao], references: [id_avaliacao], onDelete: SetNull)
  lista        TAB_LISTA?     @relation(fields: [id_lista],     references: [id_lista],     onDelete: SetNull)

  @@index([id_usuario, created_at])
  @@index([created_at])
  @@map("TAB_ATIVIDADE")
}

model TAB_DIARIO_JOGO {
  id_diario   Int      @id @default(autoincrement())
  id_usuario  Int
  id_jogo     Int
  data_jogada DateTime
  nota        Int?
  comentario  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  usuario TAB_USUARIO @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  jogo    TAB_JOGOS   @relation(fields: [id_jogo], references: [id_jogo], onDelete: Cascade)

  @@index([id_usuario, data_jogada])
  @@map("TAB_DIARIO_JOGO")
}
