# ============================================================
# Checkpoint v1.6 — Variáveis de Ambiente
# ⚠️  NUNCA commite este arquivo com valores reais em produção
# ============================================================

# Banco de dados SQLite (para produção, usar PostgreSQL)
DATABASE_URL="file:./dev.db"

# Segredo do JWT — OBRIGATÓRIO
JWT_SECRET="checkpoint_v1_6_secret_minimo_32_chars_ok"
JWT_EXPIRES_IN="7d"

# Porta da API
PORT=3333

# URL do frontend (CORS)
FRONTEND_URL="http://localhost:5173"

# Ambiente
NODE_ENV="development"

# ── Configuração Prisma ────────────────────────────────────
# Ignora erro de checksum se binários já estiverem em cache
# Útil em redes com proxy/firewall (ex: laboratório da faculdade)
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
