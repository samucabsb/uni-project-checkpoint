# ============================================================
# Checkpoint v1.5 — Variáveis de Ambiente
# ⚠️  NUNCA commite este arquivo com valores reais em produção
# ============================================================

# Banco de dados SQLite (para produção, usar PostgreSQL)
DATABASE_URL="file:./dev.db"

# Segredo do JWT — OBRIGATÓRIO, mínimo 32 caracteres
# Em produção: gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="checkpoint_v1_5_secret_minimo_32_chars_ok"

# Tempo de expiração do token
JWT_EXPIRES_IN="7d"

# Porta da API
PORT=3333

# URL do frontend (usado no CORS)
FRONTEND_URL="http://localhost:5173"

# Ambiente
NODE_ENV="development"
